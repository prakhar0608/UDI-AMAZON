# Login with Amazon (same app as Amazon Advertising API)
VITE_LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxx
VITE_LWA_CLIENT_SECRET=your_secret_here
VITE_LWA_REFRESH_TOKEN=Atzr|xxxxx

# Optional: log safe token fingerprints (len + sha256 prefix) on LWA refresh — never logs raw tokens
# AMAZON_ADS_DEBUG_AUTH=1
